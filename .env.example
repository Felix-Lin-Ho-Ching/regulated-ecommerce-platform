# PostgreSQL connection for Prisma. Use a local development database only.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stun_fry_dev?schema=public"

# Phase 1 keeps live checkout/payment/fulfillment disabled regardless of database seed data.
LIVE_CHECKOUT_ENABLED=false
LIVE_PAYMENT_ENABLED=false
LIVE_FULFILLMENT_ENABLED=false

# Local development seed credential only. Replace before production.
ADMIN_EMAIL=linhochingfelix@gmail.com
ADMIN_PASSWORD=linhochingfelix

# Payment mode: order_request until merchant/Authorize.Net approval.
PAYMENT_MODE=order_request
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_ENVIRONMENT=sandbox

EMAIL_MODE=debug
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=no-reply@example.com
EMAIL_REPLY_TO=support@example.com
SUPPORT_EMAIL=support@example.com
